{
  "name": "obfuscord",
  "version": "1.0.0",
  "description": "An obfuscation tool for Discord",
  "author": "Onlygummy",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "bun build --target node --external electron --outdir dist index.ts",
    "start": "bun run build && electron .",
    "start:debug": "bun run build && cmd /c \"set DEBUG_PROXY=true && electron .\"",
    "generate:llms": "bun run scripts/generate-llms.ts",
    "dist": "bun run build && electron-builder"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-forge": "^1.3.14",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "node-forge": "^1.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "build": {
    "appId": "com.onlygummy.obfuscord",
    "productName": "Obfuscord",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
