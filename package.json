{
  "name": "obfuscord",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "bun build --target node --external electron --outdir dist index.ts",
    "start": "bun run build && electron .",
    "start:debug": "bun run build && cmd /c \"set DEBUG_PROXY=true && electron .\"",
    "generate:llms": "bun run scripts/generate-llms.ts"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-forge": "^1.3.14",
    "electron": "^42.4.1",
    "node-forge": "^1.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
